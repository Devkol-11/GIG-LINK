{
        "compilerOptions": {
                "baseUrl": "./",
                "paths": {
                        "@core/*": ["src/core/*"],
                        "@src/*": ["src/*"]
                },
                "target": "ES2020",
                "module": "nodenext",
                "moduleResolution": "nodenext",
                "outDir": "./dist",
                "rootDir": "./",
                "strict": true,
                "esModuleInterop": true,
                "skipLibCheck": true,
                "allowSyntheticDefaultImports": true
        },
        "include": ["src", "src/core", "src/index.d.ts", "src/app.ts"]
}
